{% extends 'base.html.twig' %}

{% block title %}Exam Details - {{ exam.name }}{% endblock %}

{% block body %}
    <nav class="mb-3" aria-label="breadcrumb">
        <a href="{{ path('app_exam_index') }}" class="btn btn-secondary">&laquo; Back to list</a>
    </nav>

    <article class="p-4 bg-white rounded shadow-sm mb-5">
        <header class="mb-4 border-bottom pb-3">
            <h1 class="text-primary mb-2">Exam Details</h1>
            <h2 class="h4 text-secondary mb-3">{{ exam.name }}</h2>
            <span class="badge bg-light text-dark border p-2">Created: {{ exam.createDt|date('Y-m-d H:i') }}</span>
        </header>
        
        {% if exam.description %}
            <section class="mb-4" aria-labelledby="exam-description">
                <div class="p-3 bg-light rounded border" id="exam-description">
                    <h5 class="h6 text-muted text-uppercase mb-2">Description</h5>
                    <p class="mb-0">{{ exam.description }}</p>
                </div>
            </section>
        {% endif %}

        <section class="mb-4" aria-labelledby="exam-parameters">
            <header class="mb-3">
                <h3 id="exam-parameters" class="h5">Parameters</h3>
            </header>
            
            <div class="table-responsive rounded border">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="border-bottom-0">Name</th>
                            <th scope="col" class="border-bottom-0">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for parameter in exam.parameters %}
                            <tr>
                                <td class="fw-medium">{{ parameter.name }}</td>
                                <td>{{ parameter.value }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="2" class="text-center text-muted py-4">No parameters found.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <section class="card mt-5" aria-labelledby="add-parameter-heading">
            <header class="card-header bg-light">
                <h4 class="mb-0" id="add-parameter-heading">Add New Parameter</h4>
            </header>
            <div class="card-body">
                {{ form_start(form) }}
                    {# Zastosowana nasza krótka, prosta klasa SCSS #}
                    <div class="form-inline-align">
                        <div class="flex-grow-1">
                            {{ form_row(form.name) }}
                        </div>
                        <div class="flex-grow-1">
                            {{ form_row(form.value) }}
                        </div>
                        <div>
                            <button type="submit" class="btn btn-primary">Add Parameter</button>
                        </div>
                    </div>
                {{ form_end(form) }}
            </div>
        </section>
    </article>
{% endblock %}
